---
layout: layout
---
<% if !defined?(series_name) || !series_name %>
  <% content_for :page_title, "Series not found — macapinlac.com" %>
  <div class="wrap">
    <div class="page-head">
      <div class="eyebrow"><span class="c">$</span> ls ~/series</div>
      <h1>Series not found</h1>
      <p class="sub">That series doesn't exist. Back to <a href="/tags/">all series &amp; tags</a>.</p>
    </div>
  </div>
<% else %>
<%
  series_meta = get_series_metadata(series_name)
  published   = series_articles(series_name).sort_by(&:date)
  planned     = (series_meta && series_meta[:planned_posts]) || []
  total       = published.length + planned.length
  pct         = total.zero? ? 0 : ((published.length.to_f / total) * 100).round
  status      = series_meta ? (series_meta[:status] || (published.length == total && total > 0 ? 'complete' : 'active')) : 'active'
  color       = series_meta ? series_meta[:color] : '#c2451d'
  icon        = series_meta ? series_meta[:icon] : '🤖'
  desc        = series_meta ? series_meta[:description] : (defined?(series_description) ? series_description : '')
  slug        = series_meta ? series_meta[:slug] : series_name.downcase.gsub(/\s+/, '-')
%>
<% content_for :page_title, defined?(page_title) ? page_title : "#{series_name} — Series — macapinlac.com" %>
<% content_for :page_description, defined?(page_description) ? page_description : desc %>
<% content_for :body_attrs do %>data-screen-label="Series · <%= series_name %>" style="--c: <%= color %>"<% end %>

<div class="wrap">
  <section class="shero">
    <div class="crumb"><a href="/tags/">cd ~/series</a> / <%= slug %></div>
    <div class="badge">&bull; <%= status %> series</div>
    <div class="top">
      <div class="ico"><%= icon %></div>
      <div>
        <h1><%= series_name %></h1>
        <p class="desc"><%= desc %></p>
        <div class="meter">
          <span class="bar"><i style="width: <%= pct %>%"></i></span>
          <span class="lbl"><b><%= published.length %></b> of <%= total %> published</span>
        </div>
      </div>
    </div>
  </section>

  <div class="partshead">./parts <span class="p">— read in order</span></div>

  <% published.each_with_index do |article, idx| %>
    <%
      minutes = reading_time(article.body)
      excerpt = article_excerpt_text(article, limit: 220)
    %>
    <a class="part" href="<%= article.url %>">
      <span class="num"><span class="pre">part </span><%= '%02d' % (idx + 1) %></span>
      <div>
        <div class="dt"><%= log_date(article.date) %> · <%= minutes %> min</div>
        <div class="t"><%= article.title %></div>
        <% if excerpt %><div class="s"><%= excerpt %></div><% end %>
      </div>
      <span class="go">read <span class="a">→</span></span>
    </a>
  <% end %>

  <% planned.each_with_index do |post, planned_idx| %>
    <div class="part planned">
      <span class="num"><span class="pre">part </span><%= '%02d' % (published.length + planned_idx + 1) %></span>
      <div>
        <div class="dt">planned</div>
        <div class="t"><%= post[:title] %></div>
        <% if post[:summary] %><div class="s"><%= post[:summary] %></div><% end %>
      </div>
      <span class="badge2">// coming soon</span>
    </div>
  <% end %>
</div>
<% end %>
