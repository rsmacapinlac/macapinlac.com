<!doctype html>
<html lang="en">
  <head>
    <%= partial 'layouts/_html_head', locals: {
      title: "#{current_article.title} — macapinlac.com",
      description: current_article.data.summary || article_excerpt_text(current_article, limit: 220) || 'Personal blog and digital journal of Ritchie Macapinlac.'
    } %>
  </head>
  <body class="bl grain" data-screen-label="Article">
    <div class="progress" id="prog"></div>

    <div class="site-container">
      <%= partial 'layouts/_header' %>

      <main class="main-content">
        <%
          primary = primary_tag(current_article)
          tag_slug = primary ? primary.name.downcase.gsub(/\s+/, '-') : nil
          part_info = article_series_part(current_article)
          minutes  = reading_time(current_article.body)
        %>
        <div class="read">
          <nav class="toc toc-rail" aria-label="On this page">
            <div class="toc-h">// on this page</div>
            <ol></ol>
          </nav>

          <div class="crumb">
            <a href="/archive.html">cd ~/posts</a>
            <% if primary && tag_slug %>
              <span class="sep">/</span><a href="/tags/<%= tag_slug %>.html"><%= tag_slug %></a>
            <% end %>
            <span class="sep">/</span><%= current_article.slug %>.md
          </div>

          <article>
            <header class="phead">
              <% if part_info %>
                <a class="series-badge" href="<%= series_url(part_info[:series]) %>">
                  <%= part_info[:series][:icon] %> <%= part_info[:series][:name] %> · part <%= part_info[:number] %> of <%= part_info[:total] %>
                </a>
              <% end %>
              <h1><%= current_article.title %></h1>
              <% if current_article.data.summary %>
                <p class="lede"><%= current_article.data.summary %></p>
              <% end %>
              <div class="meta">
                <span class="k">$</span> stat post.md —
                <time datetime="<%= current_article.date.iso8601 %>"><%= log_date(current_article.date) %></time>
                · <%= minutes %> min read · by ritchie
              </div>
            </header>

            <nav class="toc toc-inline" aria-label="On this page">
              <div class="toc-h">// on this page</div>
              <ol></ol>
            </nav>

            <% if current_article.data.reply %>
              <div class="in-reply">
                <span class="lbl">// in reply to:</span>
                <%= link_to (current_article.data.reply.reply_title || current_article.data.reply.url),
                            current_article.data.reply.url, target: '_blank', rel: 'noopener' %>
              </div>
            <% end %>

            <div class="body">
              <%= yield %>
              <p class="signoff">— written in vancouver, between two cups of coffee and one questionable life choice.</p>
            </div>

            <% unless current_article.tags.empty? %>
              <div class="ptags">
                <span class="lbl"># filed under</span>
                <% current_article.tags.each do |tag| %>
                  <%= link_to tag.downcase.gsub(/\s+/, '-'), tag_path(tag), class: 'chip' %>
                <% end %>
              </div>
            <% end %>

            <aside class="author">
              <%= image_tag 'avatar-240.webp', alt: 'Ritchie Macapinlac' %>
              <div>
                <div class="nm">Ritchie Macapinlac</div>
                <p>Technology professional, parent, and serial rebuilder of perfectly functional things. Writing from Vancouver since 2000.</p>
              </div>
            </aside>

            <% prev_article = current_article.article_previous %>
            <% next_article = current_article.article_next %>
            <% if prev_article || next_article %>
              <nav class="pnav" aria-label="Adjacent posts">
                <% if prev_article %>
                  <a class="ncard prev" href="<%= prev_article.url %>">
                    <div class="d">← previous</div>
                    <div class="t"><%= prev_article.title %></div>
                  </a>
                <% else %>
                  <span></span>
                <% end %>
                <% if next_article %>
                  <a class="ncard next" href="<%= next_article.url %>">
                    <div class="d">next →</div>
                    <div class="t"><%= next_article.title %></div>
                  </a>
                <% end %>
              </nav>
            <% end %>

            <% if current_article.data.changelog %>
              <details class="changelog">
                <summary>changelog</summary>
                <ul>
                  <% current_article.data.changelog.each do |change| %>
                    <li>
                      <time datetime="<%= change.date %>"><%= change.date %></time>
                      <span><%= change.message %></span>
                    </li>
                  <% end %>
                </ul>
              </details>
            <% end %>
          </article>
        </div>
      </main>

      <%= partial 'layouts/_footer' %>
    </div>

    <script>
      function toggleTheme() {
        var current = document.documentElement.getAttribute('data-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        var lbl = document.querySelector('#themeToggle .theme-label');
        if (lbl) lbl.textContent = next === 'dark' ? '◑ dark' : '◐ light';
      }
      (function syncToggleLabel(){
        var lbl = document.querySelector('#themeToggle .theme-label');
        if (!lbl) return;
        var theme = document.documentElement.getAttribute('data-theme');
        lbl.textContent = theme === 'dark' ? '◑ dark' : '◐ light';
      })();
    </script>
  </body>
</html>
