<%
  current_url = current_page.url
  on_home    = current_url == '/' || current_url == '/index.html'
  on_about   = current_url.start_with?('/about')
  on_archive = current_url.start_with?('/archive') || current_url.start_with?('/writing')
  on_tags    = current_url.start_with?('/tags') || current_url.start_with?('/series')
%>
<header class="term-bar" role="banner">
  <div class="wrap">
    <% if on_home %>
      <form class="cmdline" id="searchForm" autocomplete="off" role="search">
        <a href="/" class="ps1" aria-label="Home">
          <span class="host">macapinlac.com</span> @ ritchie <span class="path">~ %</span>
        </a>
        <span class="fakecur" id="fakecur" aria-hidden="true"></span>
        <input id="q" class="search" type="text" placeholder="search posts" aria-label="Search posts" spellcheck="false">
      </form>
    <% else %>
      <a class="cmdline" href="/" aria-label="Home">
        <span class="ps1"><span class="host">macapinlac.com</span> @ ritchie <span class="path">~ %</span></span>
      </a>
    <% end %>

    <nav class="term-nav" role="navigation" aria-label="Primary">
      <a href="/" class="<%= 'on' if on_home %>">home</a>
      <a href="/about.html" class="about-link <%= 'on' if on_about %>">about</a>
      <a href="/archive.html" class="archive-link <%= 'on' if on_archive %>">archive</a>
      <a href="/tags/" class="<%= 'on' if on_tags %>">tags</a>
      <button type="button" class="toggle" id="themeToggle" onclick="toggleTheme()" aria-label="Toggle dark mode">
        <span class="theme-label">◐ light</span>
      </button>
    </nav>
  </div>
</header>
