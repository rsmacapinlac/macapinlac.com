---
title: "Ritchie Macapinlac — Build Log"
description: "Personal digital journal by Ritchie Macapinlac — thoughts on technology, parenting, productivity, and over-engineering perfectly functional things."
---
<%
  total_posts = blog.articles.length
  latest      = blog.articles.first
  recent      = blog.articles.first(5)
  featured    = featured_series_metadata.first
%>

<section class="hero">
  <div class="wrap">
    <div class="eyebrow"><span class="c">$</span> <%= data.homepage_hero.eyebrow %></div>
    <h1><%= data.homepage_hero.title_html.html_safe %></h1>
    <p class="sub"><%= data.homepage_hero.sub %></p>
    <div class="metaline">// <%= data.homepage_hero.metaline %> · <%= total_posts %> entries logged</div>
  </div>
</section>

<div class="wrap">
  <% if latest %>
    <% latest_color  = article_cat_color(latest) %>
    <% latest_tag    = primary_tag(latest) %>
    <% latest_minutes = reading_time(latest.body) %>
    <div class="latest" id="latestBlock" style="--cat: <%= latest_color %>">
      <a href="<%= latest.url %>">
        <div class="tagrow">
          <span class="badge">&bull; latest entry</span>
          <span class="dt"><%= log_date(latest.date) %> · <%= latest_minutes %> min</span>
        </div>
        <h2><%= latest.title %></h2>
        <% if (ex = article_excerpt_text(latest, limit: 220)) %>
          <p><%= ex %></p>
        <% end %>
        <span class="go">cat latest-post.md <span class="arr">→</span></span>
      </a>
    </div>
  <% end %>

  <section class="logsec">
    <div class="head">
      <div class="h">~/posts <span class="p">— recent writing</span></div>
      <a class="all" href="/archive.html">ls -la → all <%= total_posts %></a>
    </div>
    <div class="searchstat" id="searchstat" role="status" aria-live="polite"></div>

    <% recent.each_with_index do |article, idx| %>
      <%
        cat = article_cat_color(article)
        tag = primary_tag(article)
        minutes = reading_time(article.body)
        excerpt = article_excerpt_text(article, limit: 180)
      %>
      <a class="ix-row" href="<%= article.url %>" style="--cat: <%= cat %>">
        <span class="no"><%= '%02d' % (idx + 1) %></span>
        <span class="dt"><%= log_date(article.date) %></span>
        <div class="tw">
          <div class="t"><%= article.title %></div>
          <% if excerpt %>
            <div class="d"><%= excerpt %></div>
          <% end %>
        </div>
        <span class="meta-r">
          <span class="rt"><%= minutes %> min</span>
          <% if tag %>
            <span class="tg"><%= tag.icon %> <%= tag.name.downcase.gsub(/\s+/, '-') %></span>
          <% end %>
        </span>
      </a>
    <% end %>

    <div class="noresults" id="noresults" hidden>// no matching entries.</div>

    <% if featured %>
      <% published = series_articles(featured[:name]).length %>
      <% planned   = (featured[:planned_posts] || []).length %>
      <% total     = published + planned %>
      <a class="series-strip" id="seriesBlock" href="<%= series_url(featured) %>">
        <div class="ico"><%= featured[:icon] %></div>
        <div>
          <div class="meta"><%= featured[:status] || 'active series' %> · <%= published %> of <%= total %> published</div>
          <h3><%= featured[:name] %></h3>
          <p><%= featured[:description] %></p>
        </div>
        <span class="arr2">cd ./<%= featured[:slug] %> →</span>
      </a>
    <% end %>
  </section>
</div>
